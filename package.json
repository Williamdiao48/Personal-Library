{
  "name": "personal-library",
  "version": "0.5.2",
  "description": "A local-first desktop reading library",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "rebuild:node": "npm rebuild better-sqlite3 --build-from-source",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "fetch:model": "node scripts/ml/fetch-embedding-model.mjs",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.9",
    "@huggingface/transformers": "^4.2.0",
    "@mozilla/readability": "^0.5.0",
    "@tanstack/react-virtual": "^3.13.23",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^11.0.0",
    "electron-updater": "^6.3.9",
    "epub-gen-memory": "^1.1.2",
    "jsdom": "^24.1.1",
    "pdfjs-dist": "^5.4.624",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "sanitize-html": "^2.13.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/adm-zip": "^0.5.5",
    "@types/better-sqlite3": "^7.6.11",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sanitize-html": "^2.13.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.9.4",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.3.4",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.personal-library.app",
    "productName": "Personal Library",
    "icon": "build/icon.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "!**/node_modules/@napi-rs/canvas*/**"
    ],
    "extraResources": [
      {
        "from": "resources/models",
        "to": "models"
      }
    ],
    "asarUnpack": [
      "**/node_modules/onnxruntime-node/bin/**",
      "**/node_modules/onnxruntime-web/dist/*.wasm"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.books",
      "icon": "build/icon.icns",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "Williamdiao48",
      "repo": "Personal-Library"
    }
  }
}
