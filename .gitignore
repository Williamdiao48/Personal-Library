# Dependencies
node_modules/

# Build output (electron-vite → out/, electron-builder → dist/)
out/
dist/
dist-electron/

# Test / coverage artifacts
coverage/
test-results/
playwright-report/
*.tsbuildinfo

# Local node-gyp venv (setuptools shim for Python 3.12+; see docs/testing.md)
.gyp-venv/

# SQLite database files (user data — never commit)
*.db
*.db-journal
*.db-wal
*.db-shm
# ...except the bundled read-only WordNet dictionary, a committed build artifact
# (see scripts/dictionary/build.mjs).
!resources/dictionary/dictionary.db

# Environment / secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Vite local overrides
*.local

# IDE
.vscode/
.idea/

# electron-builder cache
.cache/

# Vendored ML model — ~35 MB, no git-lfs here; run `npm run fetch:model` to
# populate. See scripts/ml/fetch-embedding-model.mjs.
resources/models/

# Internal docs — never publish (architecture/parser references, planning,
# audits, and the development journal). See docs/internal/README.md.
docs/internal/

# Internal security audit — kept local only, must never be committed/published.
security.md

# Cloud Phase 0 throwaway spikes (R2 / Turso de-risking experiments). Own
# package.json + creds; never ship. See docs/internal/planning/cloud/phase-0-foundations.md.
spikes/

# Throwaway eyeball-gate harnesses — opt-in, run against a COPY of the real
# library. Named *.harness.test.ts so vitest can run them by path, but never
# committed (they embed with the real model and read the user's real content).
*.harness.test.ts
